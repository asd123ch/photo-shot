# Photo-Shot configuration
#
# Copy to ".env" and fill in. docker-compose passes these into the container.
#
# The API keys stay on the SERVER: nginx proxies /api/<provider>/ to each
# provider and injects the key (see app/docker/render-config.sh + nginx.conf).
# They are NOT shipped to the browser. Every /api request must carry the unlock
# password (APP_PASSWORD), which nginx verifies, so the keys cannot be reached
# from the internet without it.

# Google Gemini API key (direct) — Nano Banana 2 / Pro.
GEMINI_API_KEY=

# WaveSpeed API key — Seedream, Nano Banana, GPT Image, MAI, Recraft, …
WAVESPEED_API_KEY=

# OpenRouter API key — the OpenRouter-routed models.
OPENROUTER_API_KEY=

# Password to unlock the app. This is the REAL gate now: nginx checks it on
# every /api call, so without it nobody can use the models or reach the keys.
# Choose something strong.
APP_PASSWORD=change-me

# Cloudflare Tunnel token — exposes the app publicly without opening ports.
# Generate it on your own machine / in the Cloudflare dashboard (see README),
# then paste it here. Leave empty to disable the tunnel (the cloudflared
# container will just keep restarting if it is empty).
CLOUDFLARE_TUNNEL_TOKEN=

# ---------------------------------------------------------------------------
# Local development (cd app && npm run dev): there is no /api proxy in dev, so
# image generation only works against the deployed container. The dev server
# treats all providers as available and accepts any unlock password.
